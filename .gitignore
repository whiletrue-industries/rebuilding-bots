.checkpoints/
.DS_Store
# Default LocalFsStore root for the ArtifactStore (botnim/storage); dev/CI
# artifact working set under <repo-root>/tmp/artifacts. Never committed.
/tmp/
.env
# Local-dev launcher overrides — points at local pgvector docker, never
# meant to be committed (would override prod env vars if pulled in by CI).
.env.local-dev
out/
botnim.egg-info/
__pycache__/
.cursor/rules/onboarding.mdc
venv/
.venv/

firebase-credentials.json

# Generated by `botnim sync` -- code-managed bot configs published at sync
# time for LibreChat / FastAPI consumption. Source of truth is specs/<bot>/.
specs/.published/

# Local-only superpowers worktree area for isolated feature branches.
.worktrees/

# Staged copy of parlibot/deploy/ files for docker build context (populated
# by parlibot/deploy.sh phase 3 immediately before docker build). The
# directory itself is ignored EXCEPT for gold-set.json, which carries a
# committed empty-array stub so CI Docker builds can satisfy the Dockerfile
# COPY without parlibot in the build context. deploy.sh phase 3 overwrites
# the stub with the real gold-set before each prod docker build.
/deploy/*
!/deploy/gold-set.json
